# ---- LakeLevelNow environment ----
# Copy to `.env` for local dev. Data fetch needs NO API keys (USGS + CDEC are keyless).

# Canonical production origin (used for canonical/sitemap/OG absolute URLs).
# Also set in astro.config.mjs (site:) — keep them in sync.
SITE=https://lakelevelnow.com

# ---- Launch / deploy (set in GitHub Actions secrets, not local) ----
# Cloudflare — token needs Zone:Zone:Edit, Zone:DNS:Edit, Workers Scripts:Edit.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Porkbun — for the DNS nameserver cutover (scripts/porkbun-set-ns.mjs).
# PORKBUN_APIKEY=
# PORKBUN_SECRET=

# Google Search Console — paste the token from "Domain name provider" verification
# to add the DNS TXT via scripts/cf-zone-create.mjs (no quotes/leading text).
# GOOGLE_SITE_VERIFICATION=
