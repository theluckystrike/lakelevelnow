---
// Global footer: link columns + the honesty disclaimer.
import { SITE, AFFILIATES, AFFILIATE_REPLACE_ME } from '../consts';
import { LAKES } from '../lib/lakes';

// Featured lakes (prefer those with live readings; else high-volume registry entries).
const featured = LAKES.slice(0, 6);
const more = LAKES.slice(6, 14);
---
<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div>
        <h4>Lakes</h4>
        <ul>
          <li><a href="/lakes">All lakes</a></li>
          {featured.map((l) => <li><a href={`/lake/${l.slug}`}>{l.name}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>More lakes</h4>
        <ul>
          {more.map((l) => <li><a href={`/lake/${l.slug}`}>{l.name}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>Site</h4>
        <ul>
          <li><a href="/about">About &amp; data sources</a></li>
          <li><a href="/disclosure">Affiliate disclosure</a></li>
          <li><a href={`mailto:${SITE.contactEmail}`}>Contact</a></li>
        </ul>
      </div>
    </div>
    <p class="disclaimer">
      {SITE.name} republishes public water-data from the USGS Water Services and the California Data Exchange (CDEC).
      Levels are point-in-time readings from those feeds and can lag real conditions; always confirm current ramp and
      hazard status with the lake operator (USACE, USBR, state agency, or local authority) before you go on the water.
      Percent-full is computed from reported storage or elevation against each reservoir’s published capacity; treat it
      as a guide, not an official figure. Not affiliated with any government agency.
      {AFFILIATE_REPLACE_ME
        ? ' Some pages carry recreation-affiliate links once the affiliate accounts are wired (currently placeholders).'
        : ' Some links on recreation pages are affiliate links — see the disclosure page.'}
    </p>
    <p class="mut" style="margin-top:10px">© {SITE.name}. Built {new Date().getFullYear()}.</p>
  </div>
</footer>
