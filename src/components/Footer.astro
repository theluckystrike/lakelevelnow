---
// Global footer — dark slate, LakeLevelNow wordmark, data attribution, disclaimer.
import { SITE, AFFILIATE_REPLACE_ME } from '../consts';
import { LAKES, freshLakes } from '../lib/lakes';
const featured = freshLakes().slice(0, 6).map((x) => x.lake);
const more = LAKES.slice(6, 14);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="frow">
      <div>
        <div class="fbrand"><span class="w">Lake</span><span class="b">Level</span><span class="w">Now</span></div>
        <div class="fdata">Data: USGS Water Services · CDEC</div>
      </div>
      <div class="flinks">
        <a href="/about">About &amp; data</a>
        <a href="/lakes">All lakes</a>
        <a href="/disclosure">Disclosure</a>
        <a href={`mailto:${SITE.contactEmail}`}>Contact</a>
      </div>
    </div>
    <p class="disclaimer">
      {SITE.name} republishes public water-data from the USGS Water Services and the California Data Exchange (CDEC).
      Levels are point-in-time readings and can lag real conditions; always confirm ramp and hazard status with the
      lake operator before you go on the water. Not affiliated with any government agency.
      {AFFILIATE_REPLACE_ME
        ? ' Recreation-affiliate links appear on lake pages once partner accounts are wired.'
        : ' Some lake-page links are affiliate — see the disclosure page.'}
    </p>
    <div class="copy">© {SITE.name} {year}</div>
  </div>
</footer>
