---
// Global footer — dark slate, LakeLevelNow wordmark, zovo.one + GitHub, disclaimer.
import { SITE, AFFILIATE_REPLACE_ME } from '../consts';
import { LAKES, freshLakes } from '../lib/lakes';
const featured = freshLakes().slice(0, 6).map((x) => x.lake);
const more = LAKES.slice(6, 14);
const year = new Date().getFullYear();
const ZOVO = 'https://zovo.one';
const GH = 'https://github.com/theluckystrike';
---
<footer class="site-footer">
  <div class="container">
    <div class="frow">
      <div>
        <div class="fbrand"><span class="w">Lake</span><span class="b">Level</span><span class="w">Now</span></div>
        <div class="fdata">Built solo · Data: USGS Water Services · CDEC</div>
      </div>
      <div class="flinks">
        <a href="/about">About</a>
        <a href="/lakes">All lakes</a>
        <a href="/disclosure">Disclosure</a>
        <a href={GH} rel="nofollow noopener">GitHub</a>
        <a href={ZOVO} rel="nofollow noopener">zovo.one</a>
        <a href={`mailto:${SITE.contactEmail}`}>Contact</a>
      </div>
    </div>
    <p class="disclaimer">
      {SITE.name} republishes public water-data from the USGS Water Services and the California Data Exchange (CDEC).
      Levels are point-in-time readings and can lag real conditions; always confirm ramp and hazard status with the
      lake operator before you go on the water. Not affiliated with any government agency.
      {AFFILIATE_REPLACE_ME
        ? ' Recreation-affiliate links appear on lake pages once partner accounts are wired.'
        : ' Some lake-page links are affiliate. See the disclosure page.'}
    </p>
    <div class="copy">© {SITE.name} {year} · A <a href={ZOVO} rel="nofollow noopener" style="color:rgba(255,255,255,.4);text-decoration:underline;">zovo.one</a> site, built by one developer.</div>
  </div>

<!-- Empire: related calculators (topically relevant sibling tools) -->
<section class="empire-related" aria-label="Related calculators" style="max-width:760px;margin:48px auto 64px;padding:24px 28px;border:1px solid #e3e6ec;border-radius:14px;background:#fafbfc;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1f2933">
  <h2 style="margin:0 0 10px;font-size:18px;font-weight:700;letter-spacing:-.01em">Related calculators</h2>
  <p style="margin:0 0 14px;font-size:14px;color:#52606d">More free tools from our network: live lake & reservoir water levels and beyond.</p>
  <ul style="list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:8px 18px;font-size:14px">
      <li><a href="https://earlythunder.com/">storm & severe-weather tracker</a></li>
      <li><a href="https://examscorecalc.com/">grade & test-score calculator</a></li>
  </ul>
</section>
<!-- /Empire -->

</footer>
