---
// LakeGauge — the live reading, above the fold. 270° arc gauge + 3×2 stat grid +
// "Can I launch?" verdict + ~30-day sparkline. Pure server-rendered SVG (no client JS).
import type { LakeEntry, Reading } from '../lib/lakes';
import { launchRead, status, fmtNum } from '../lib/lakes';

interface Props { lake: LakeEntry; reading: Reading }
const { lake, reading } = Astro.props;

const hasPct = reading.pct_full != null;
const pct = hasPct ? (reading.pct_full as number) : null;
const st = status(pct, reading.feet_from_full);
const tone = st.tone === 'green' || st.tone === 'cyan' ? '#0b7d6a' : st.tone === 'amber' ? '#b07d1a' : st.tone === 'red' ? '#bb5a37' : '#8a949a';

// 270° arc gauge geometry (r=80, gap at bottom via rotate(135deg)).
const R = 80, C = 2 * Math.PI * R, ARC = C * 0.75;
const fillArc = hasPct ? (Math.max(0, Math.min(100, pct as number)) / 100) * ARC : 0;
const trackDash = `${ARC} ${C}`;
const fillDash = `${fillArc} ${C}`;

const launch = launchRead(reading);
const asOf = reading.as_of ? new Date(reading.as_of).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';

// Sparkline (~30-day series).
const series = (reading.series || []).map((s) => s.v).filter((v) => Number.isFinite(v));
let spark = '', sparkEndY = 100, sparkLo = '', sparkHi = '';
if (series.length >= 2) {
  const mn = Math.min(...series), mx = Math.max(...series), rg = (mx - mn) || 1;
  const W = 100, H = 100;
  const sx = (i: number) => (i / (series.length - 1)) * W;
  const sy = (v: number) => H - ((v - mn) / rg) * 80;
  const line = series.map((v, i) => `${i ? 'L' : 'M'}${sx(i).toFixed(2)},${sy(v).toFixed(2)}`).join(' ');
  const area = `M0,${H} L${series.map((v, i) => `${sx(i).toFixed(2)},${sy(v).toFixed(2)}`).join(' L')} L${W},${H} Z`;
  sparkEndY = sy(series[series.length - 1]);
  spark = `<path d="${area}" fill="${tone}" fill-opacity="0.07"></path><polyline points="${series.map((v, i) => `${sx(i).toFixed(2)},${sy(v).toFixed(2)}`).join(' ')}" fill="none" stroke="${tone}" stroke-width="1.5" vector-effect="non-scaling-stroke" stroke-linejoin="round"></polyline><circle cx="100" cy="${sparkEndY.toFixed(2)}" r="3" fill="${tone}" vector-effect="non-scaling-stroke"></circle>`;
  sparkLo = fmtNum(mn, mn > 1000 ? 0 : 1);
  sparkHi = fmtNum(mx, mx > 1000 ? 0 : 1);
}
const deltaUp = (reading.delta_24h ?? 0) >= 0;
---

<div class="lake-hero">
  <!-- Gauge card -->
  <div class="gauge-card">
    <svg class="gauge" viewBox="0 0 200 200" role="img" aria-label={hasPct ? `${lake.name} is ${pct}% full` : `${lake.name} level ${fmtNum(reading.level_ft,1)} ft`}>
      <circle cx="100" cy="100" r={R} fill="none" stroke="#ebe7e0" stroke-width="13" stroke-linecap="round" stroke-dasharray={trackDash} transform="rotate(135 100 100)"></circle>
      <circle cx="100" cy="100" r={R} fill="none" stroke={tone} stroke-width="13" stroke-linecap="round" stroke-dasharray={fillDash} transform="rotate(135 100 100)" style="animation: gaugeIn 1.2s ease-out;"></circle>
      {hasPct ? (
        <>
          <text x="100" y="92" text-anchor="middle" style="font-family:'Space Grotesk',sans-serif;font-size:48px;font-weight:700;fill:#16282f;letter-spacing:-0.03em;">{pct}</text>
          <text x="100" y="116" text-anchor="middle" style="font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:500;fill:#5c6a70;">% full</text>
        </>
      ) : (
        <>
          <text x="100" y="92" text-anchor="middle" style="font-family:'Space Grotesk',sans-serif;font-size:30px;font-weight:700;fill:#16282f;letter-spacing:-0.03em;">{fmtNum(reading.level_ft,1)}</text>
          <text x="100" y="116" text-anchor="middle" style="font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:500;fill:#5c6a70;">ft msl</text>
        </>
      )}
    </svg>
    <div class="sub-line">
      <span class={`pill ${st.tone === 'red' ? 'red' : st.tone === 'amber' ? 'amber' : 'green'}`}>{st.label}</span>
      {reading.feet_from_full != null && <span style="font-size:13px;color:var(--t2);">{fmtNum(Math.abs(reading.feet_from_full),1)} ft {reading.feet_from_full > 0 ? 'below' : 'above'} full pool</span>}
    </div>
    <div class="src-foot">
      <span class="src-badge">{reading.feed}</span>
      <span style="font-size:11px;color:var(--t3);">{reading.storage_af != null ? `${fmtNum(reading.storage_af,0)} acre-ft · ` : ''}updated {asOf}</span>
    </div>
  </div>

  <!-- Stats grid 3×2 -->
  <div class="stat-grid">
    {hasPct && <div class="stat-cell"><div class="v" style={`color:${tone}`}>{pct}%</div><div class="l">percent full</div></div>}
    {reading.level_ft != null && <div class="stat-cell"><div class="v">{fmtNum(reading.level_ft,1)}</div><div class="l">{reading.param.includes('gage') ? 'gage height (ft)' : 'water level (ft msl)'}</div></div>}
    {reading.feet_from_full != null && <div class="stat-cell"><div class={`v ${reading.feet_from_full > 0 ? 'down' : 'up'}`}>{fmtNum(Math.abs(reading.feet_from_full),1)}</div><div class="l">{reading.feet_from_full > 0 ? 'ft below full pool' : 'ft above full pool'}</div></div>}
    {reading.delta_24h != null && <div class="stat-cell"><div class={`v ${deltaUp ? 'up' : 'down'}`}>{deltaUp ? '+' : '−'}{fmtNum(Math.abs(reading.delta_24h),2)}</div><div class="l">24-hour change (ft)</div></div>}
    {lake.full_pool_ft != null && <div class="stat-cell"><div class="v">{fmtNum(lake.full_pool_ft,0)}</div><div class="l">full pool (ft ref.)</div></div>}
    {lake.capacity_af != null && <div class="stat-cell"><div class="v">{fmtNum(lake.capacity_af/1e6,2)}M</div><div class="l">capacity (acre-ft)</div></div>}
  </div>
</div>

<!-- Can I launch? verdict -->
<div class={`verdict ${launch.ok ? '' : 'warn'}`}>
  <div class="ic">
    {launch.ok
      ? <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9.5L7.5 13L14 5" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      : <span style="font-size:18px;font-weight:800;line-height:1;">!</span>}
  </div>
  <div>
    <div class="vt">Can I launch? <span class="ok">{launch.ok ? 'Yes — most ramps usable.' : 'Check before you go.'}</span></div>
    <div class="vb">{launch.text}</div>
  </div>
</div>

<!-- Trend -->
{series.length >= 2 && (
  <div class="chartcard">
    <div class="ch-head">~30-day trend · {reading.param}</div>
    <svg class="spark" viewBox="0 0 100 100" preserveAspectRatio="none" set:html={spark} />
    <div class="ch-foot">
      <span class="lo">{sparkHi}</span>
      <span><span class="now">{series[series.length-1] >= 1000 ? fmtNum(series[series.length-1],0) : fmtNum(series[series.length-1],1)}</span> <span style="font-size:11px;font-weight:500;color:var(--t3);">now</span></span>
      <span class="lo">{sparkLo}</span>
    </div>
  </div>
)}
