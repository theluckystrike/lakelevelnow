---
// Page shell: head SEO + header + main slot + footer. Used by every page.
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { organizationLd, websiteLd } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any>[];
}
const { title, description, path, ogImage, noindex, jsonLd = [] } = Astro.props;
const ld = [organizationLd(), websiteLd(), ...jsonLd];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      noindex={noindex}
      jsonLd={ld}
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
