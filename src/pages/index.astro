---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
import { LAKES, freshLakes, byState, getReading, status, fmtNum, stateName } from '../lib/lakes';
import { faqLd, breadcrumbLd } from '../lib/seo';

const title = 'Live US lake & reservoir water levels';
const description = SITE.description;

const fresh = freshLakes();
// Biggest movers = largest absolute 24h change among fresh lakes.
const movers = [...fresh]
  .map(({ lake, reading }) => ({ lake, reading, d: Math.abs(reading.delta_24h ?? 0) }))
  .sort((a, b) => b.d - a.d)
  .slice(0, 6);
const states = byState();

const faqs = [
  { q: 'Where does the lake level data come from?', a: `Directly from public water-data feeds: the USGS Water Services for most lakes and the California Data Exchange (CDEC) for California reservoirs. ${SITE.name} fetches each lake's own gage, so the number you see is the same one the operator reports — not a scrape of another website.` },
  { q: 'How often are the levels updated?', a: 'The pipeline refreshes readings regularly (and on a weekly schedule in CI). USGS instantaneous gages update as often as every 15–60 minutes; CDEC storage is daily. Each reading carries a timestamp and source badge so you can see exactly when it was taken.' },
  { q: 'What does "percent full" mean?', a: "It's the reservoir's current storage (or elevation) divided by its published full capacity, as a percentage. 100% means the lake is at its designed full pool; low percentages indicate drawdown, often for drought, flood control, or water supply. We compute it from the feed's reported storage where available." },
  { q: 'Is the level shown right now, in real time?', a: 'Almost — it is the most recent reading the source has published, which is usually minutes to hours old. Conditions can change with releases, rainfall, or gate operations, so confirm current ramp and hazard status with the lake operator before heading out.' },
];
const ld = [faqLd(faqs), breadcrumbLd([{ name: 'Home', path: '/' }])];
---
<BaseLayout title={title} description={description} path="/" jsonLd={ld}>
  <div class="container">
    <section class="hero">
      <h1>Live US lake &amp; reservoir water levels</h1>
      <p class="lead">
        Current level, percent full, and a 30-day trend for lakes across the country — pulled straight from
        USGS and CDEC gages, with a plain-English read on whether you can launch a boat. No login, no ads in your face.
      </p>
    </section>

    <div class="ticker">
      <span class="live"><span class="dot"></span> Live now</span>
      {fresh.slice(0, 8).map(({ lake, reading }) => (
        <span class="item">
          <a href={`/lake/${lake.slug}`} class="name">{lake.name}</a>
          <span class="v">{reading.pct_full != null ? `${reading.pct_full}%` : `${fmtNum(reading.level_ft,1)}ft`}</span>
        </span>
      ))}
    </div>

    <section class="section">
      <h2>Lakes with a current reading</h2>
      <p class="mut">These have a verified, in-date live gage right now. Tap a lake for the full gauge, trend, and launch read.</p>
      <div class="grid cols-3" style="margin-top:14px">
        {fresh.map(({ lake, reading }) => {
          const st = status(reading.pct_full);
          return (
            <a class="card" href={`/lake/${lake.slug}`} style="text-decoration:none;color:inherit">
              <h3>{lake.name}</h3>
              <div class={`num ${st.tone === 'green' ? 'g' : st.tone === 'red' ? 'r' : st.tone === 'amber' ? 'a' : ''}`}>
                {reading.pct_full != null ? `${reading.pct_full}%` : `${fmtNum(reading.level_ft,1)} ft`}
              </div>
              <p class="mut" style="margin:6px 0 0">{lake.river} · {lake.state} · <span class={`pill ${st.tone}`}>{st.label}</span></p>
            </a>
          );
        })}
      </div>
    </section>

    {movers.length > 0 && (
      <section class="section">
        <h2>Biggest 24-hour movers</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Lake</th><th>State</th><th class="num">Level</th><th class="num">24h change</th></tr></thead>
            <tbody>
              {movers.map(({ lake, reading }) => (
                <tr>
                  <td><a href={`/lake/${lake.slug}`}><b>{lake.name}</b></a></td>
                  <td>{lake.state}</td>
                  <td class="num">{reading.pct_full != null ? `${reading.pct_full}%` : `${fmtNum(reading.level_ft,1)} ft`}</td>
                  <td class={`num ${(reading.delta_24h ?? 0) >= 0 ? 'up' : 'down'}`}>{(reading.delta_24h ?? 0) >= 0 ? '+' : ''}{fmtNum(reading.delta_24h,2)} ft</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="section">
      <h2>Browse by state</h2>
      <div class="state-grid" style="margin-top:12px">
        {Object.entries(states).map(([code, lakes]) => (
          <a href={`/lakes#${code}`}>
            <span>{stateName(code)}</span>
            <span class="tag">{lakes.length} lakes</span>
          </a>
        ))}
      </div>
      <p style="margin-top:12px"><a href="/lakes">See all {LAKES.length} lakes in the registry &rarr;</a></p>
    </section>

    <section class="section">
      <h2>Common questions</h2>
      {faqs.map((f) => (
        <div style="margin-bottom:14px">
          <h3 style="font-size:1.05rem">{f.q}</h3>
          <p class="mut" style="margin:4px 0 0">{f.a}</p>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>
