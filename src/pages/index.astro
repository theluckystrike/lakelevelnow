---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
import { LAKES, freshLakes, byState, getReading, status, fmtNum, stateName } from '../lib/lakes';
import { authorLd, breadcrumbLd } from '../lib/seo';

const title = 'Live US lake & reservoir water levels';
const description = SITE.description;
const fresh = freshLakes();
const toneHex = (t: string) => t === 'red' ? '#bb5a37' : t === 'amber' ? '#b07d1a' : t === 'green' || t === 'cyan' ? '#0b7d6a' : '#8a949a';

const movers = [...fresh]
  .map(({ lake, reading }) => ({ lake, reading, d: Math.abs(reading.delta_24h ?? 0) }))
  .sort((a, b) => b.d - a.d)
  .slice(0, 6);

const states = byState();

const faqs = [
  { q: 'Where does the lake level data come from?', a: `Directly from public water-data feeds: USGS Water Services for most lakes and CDEC for California reservoirs. ${SITE.name} fetches each lake's own gage — the number you see is the same one the operator reports.` },
  { q: 'How often are the levels updated?', a: 'USGS instantaneous gages update every 15–60 minutes; CDEC storage is daily. Each reading carries a timestamp so you can see exactly when it was taken.' },
  { q: 'What does "percent full" mean?', a: 'Current storage divided by published full capacity, as a percentage. 100% means full pool; low percentages indicate drawdown for drought, flood control, or water supply.' },
  { q: 'Is the level shown in real time?', a: 'Almost — it is the most recent reading from the source, usually minutes to hours old. Always confirm conditions with the lake operator before heading out.' },
];
const ld = [authorLd(), breadcrumbLd([{ name: 'Home', path: '/' }])];
---
<BaseLayout title={title} description={description} path="/" jsonLd={ld}>
  <div class="container">

    <section class="hero">
      <div class="live-badge"><span class="dot"></span><span>{fresh.length} lakes live now</span></div>
      <h1>Live US lake &amp; reservoir water levels</h1>
      <p class="lead">Percent full and 30-day trend from USGS and CDEC gages, with a plain-English read on whether you can launch a boat.</p>
    </section>

    <section class="section">
      <div class="head-row">
        <h2>Lakes with a current reading</h2>
        <a class="see-all" href="/lakes">See all →</a>
      </div>
      <div class="grid cols-2">
        {fresh.map(({ lake, reading }) => {
          const st = status(reading.pct_full, reading.feet_from_full);
          const hex = toneHex(st.tone);
          const val = reading.pct_full != null ? `${reading.pct_full}%` : `${fmtNum(reading.level_ft,1)} ft`;
          // Elevation-only lakes have no %full; size the bar to the status bucket
          // (a qualitative proxy) so it never reads a misleading 0% on a live lake.
          const barProxy = ({ green: 92, cyan: 72, amber: 48, red: 18 } as const)[st.tone];
          const bar = reading.pct_full != null ? `${reading.pct_full}%` : `${barProxy}%`;
          return (
            <a class="lake-card" href={`/lake/${lake.slug}`}>
              <div class="top">
                <div><div class="name">{lake.name}</div><div class="sub">{lake.river} · {lake.state}</div></div>
                <div class="val" style={`color:${hex}`}>{val}</div>
              </div>
              <div class="status-row"><span class="d" style={`background:${hex}`}></span><span>{st.label}</span></div>
              <div class="bar"><i style={`width:${bar};background:${hex}`}></i></div>
            </a>
          );
        })}
      </div>
    </section>

    {movers.length > 0 && (
      <section class="section">
        <h2 style="margin-bottom:16px;">Biggest 24-hour movers</h2>
        <div class="table-wrap">
          <table class="movers">
            <thead><tr><th>Lake</th><th>State</th><th class="num">Level</th><th class="num">24h Δ (ft)</th></tr></thead>
            <tbody>
              {movers.map(({ lake, reading }) => {
                const d = reading.delta_24h ?? 0;
                return (
                  <tr>
                    <td><a href={`/lake/${lake.slug}`}><b>{lake.name}</b></a></td>
                    <td class="mut">{lake.state}</td>
                    <td class="num">{reading.pct_full != null ? `${reading.pct_full}%` : `${fmtNum(reading.level_ft,1)} ft`}</td>
                    <td class="num chg">{d >= 0 ? '+' : '−'}{fmtNum(Math.abs(d),0)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="section">
      <h2 style="margin-bottom:16px;">Browse by state</h2>
      <div class="state-grid">
        {Object.entries(states).sort((a,b)=>stateName(a[0]).localeCompare(stateName(b[0]))).map(([code, lakes]) => (
          <a href={`/lakes#${code}`}><div class="sn">{stateName(code)}</div><div class="sc">{lakes.length} lakes</div></a>
        ))}
      </div>
      <div style="margin-top:16px;"><a class="see-all" href="/lakes">See all {LAKES.length} lakes in the registry →</a></div>
    </section>

    <section class="section">
      <h2 style="margin-bottom:4px;">Common questions</h2>
      {faqs.map((f) => (
        <div class="faq-item"><div class="q">{f.q}</div><div class="a">{f.a}</div></div>
      ))}
    </section>

  </div>
</BaseLayout>
