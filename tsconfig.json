{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@data/*": ["src/data/*"]
    },
    "verbatimModuleSyntax": true
  },
  "include": ["src", "scripts", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules"]
}
